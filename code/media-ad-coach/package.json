{
  "name": "visibel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "test": "vitest run",
    "check-env": "tsx scripts/check-env.ts",
    "smoke:api": "tsx scripts/smoke-api.ts",
    "demo": "(lsof -ti tcp:3000 | xargs kill 2>/dev/null || true) && NEXT_DIST_DIR=.next-build next build && NEXT_DIST_DIR=.next-build DEMO_MODE=replay next start -p 3000",
    "demo:live": "(lsof -ti tcp:3000 | xargs kill 2>/dev/null || true) && NEXT_DIST_DIR=.next-build next build && NEXT_DIST_DIR=.next-build next start -p 3000",
    "demo:stop": "lsof -ti tcp:3000 | xargs kill 2>/dev/null || true"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tavily/core": "^0.7.6",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "next": "15.5.20",
    "openai": "^6.48.0",
    "playwright": "1.61.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
