OPENAI_API_KEY=
TAVILY_API_KEY=
COGNEE_API_KEY=
COGNEE_API_URL=
COGNEE_DATASET_NAME=visibel-audits
COGNEE_AUTH_MODE=
DEMO_MODE=live
OPENAI_MODEL_TEXT=gpt-5.6-luna
OPENAI_MODEL_VISION=gpt-5.6-luna
# Human decision 2026-07-21: gpt-image-2 is the image model, chosen for QUALITY.
# Its latency is variable (measured on this account, same 1536x1024/medium hero call:
# 38.5s once, >500s another time), so it is absorbed by the FLOW, not by a faster model:
# FEA-112 generates images asynchronously (the report completes first) and streams
# partial frames, so a real image appears ~13s in and the final lands ~40-60s in.
# Never swap this for a faster model to "fix" a timeout — fix the flow instead.
OPENAI_MODEL_IMAGE=gpt-image-2
# FEA-112 image knobs (all optional; shown with their defaults):
#   OPENAI_IMAGE_TIMEOUT_MS=900000        total per-call budget
#   OPENAI_IMAGE_STALL_TIMEOUT_MS=120000  max silence BETWEEN streamed events ("dead" test)
#   OPENAI_IMAGE_STREAM=0                 opt out of streaming (loses partial frames)
#   OPENAI_IMAGE_QUALITY=low|medium|high  default medium
